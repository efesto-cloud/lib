{
    "$schema": "https://unpkg.com/knip@6/schema.json",
    "workspaces": {
        ".": {
            "entry": ["scripts/*.mjs"],
            "project": ["scripts/**/*.mjs"]
        },
        "example": {
            "entry": ["src/index.ts"],
            "project": ["src/**/*.ts"]
        },
        "packages/audit": {
            "entry": ["examples/*.ts"]
        }
    },
    "ignoreExportsUsedInFile": true
}
