{
    "name": "@efesto-cloud/publisher",
    "version": "0.0.2",
    "description": "Publisher type for efesto-cloud",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/efesto-cloud/lib.git",
        "directory": "packages/publisher"
    },
    "type": "module",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./*": {
            "import": "./dist/*.js",
            "types": "./dist/*.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc --project tsconfig.json",
        "typecheck": "tsc --noEmit",
        "clean": "rm -rf dist"
    },
    "keywords": [],
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    }
}
