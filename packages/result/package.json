{
    "name": "@efesto-cloud/result",
    "version": "1.0.0",
    "description": "Result type for efesto-cloud",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/efesto-cloud/lib.git",
        "directory": "packages/result"
    },
    "type": "module",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./*": {
            "import": "./dist/*.js",
            "types": "./dist/*.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc --project tsconfig.json",
        "typecheck": "tsc --noEmit",
        "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
        "test": "tsx --test \"src/**/*.test.ts\"",
        "clean": "rm -rf dist"
    },
    "devDependencies": {
        "@types/node": "24",
        "zod": "^4"
    },
    "keywords": [],
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    }
}
