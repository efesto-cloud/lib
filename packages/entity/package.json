{
    "name": "@efesto-cloud/entity",
    "version": "0.0.1",
    "description": "Entity type for efesto-cloud",
    "type": "module",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        "./*": {
            "import": "./dist/*.js",
            "types": "./dist/*.d.ts"
        },
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc --project tsconfig.json",
        "typecheck": "tsc --noEmit",
        "clean": "rm -rf dist"
    },
    "keywords": [],
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "peerDependencies": {
        "luxon": "^3"
    },
    "devDependencies": {
        "@types/luxon": "^3"
    }
}
